# Copy from docs/ai/environments/staging.env (STAGING_BACKEND_API). Must match Railway
# backend **Networking → Public URL** + `/api`.
# Railway builds the public host as `{service}-{environment}.up.railway.app`. If the
# service slug already ends with `-staging` and the environment is `staging`, you
# will see `…-staging-staging…` — that is normal, not a typo.
VITE_API_URL=https://zephix-backend-staging-staging.up.railway.app/api
VITE_STRICT_JWT=false
VITE_SENTRY_ENVIRONMENT=staging
