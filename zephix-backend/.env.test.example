# Copy to `.env.test` and fill with real values (never commit `.env.test`).
# Railway: zephix-postgres-test → DATABASE_URL; zephix-backend (test env) → JWT_SECRET.
# See GET_RAILWAY_VALUES.md
#
# Full AppModule boot (e2e / integration tests that call createNestApplication + init)
# requires the variables below. Missing any of them produces failures during
# module compilation (e.g. JWT_SECRET, INTEGRATION_ENCRYPTION_KEY), not in the
# test body. See docs/architecture/runtime-guardrail-scope.md.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
JWT_SECRET=generate-with-openssl-rand-hex-64
NODE_ENV=test

# Minimum 32 characters (IntegrationEncryptionService constructor).
INTEGRATION_ENCRYPTION_KEY=replace-with-32-plus-char-secret-for-local-test-only

# Required for login / refresh / token flows in integration tests
REFRESH_TOKEN_PEPPER=openssl-rand-hex-32-chars-minimum-required-here
TOKEN_HASH_SECRET=openssl-rand-hex-32-chars-minimum-required-here
JWT_REFRESH_SECRET=openssl-rand-hex-32-chars-minimum-required-here
