{
  "mcpServers": {
    "railway-mcp": {
      "command": "node",
      "args": ["${workspaceFolder}/node_modules/@railway/mcp-server/dist/index.js"],
      "env": {
        "RAILWAY_TOKEN": "${env:RAILWAY_TOKEN}"
      }
    },
    "github-mcp": {
      "command": "node",
      "args": ["${workspaceFolder}/node_modules/@modelcontextprotocol/server-github/dist/index.js"],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "filesystem-mcp": {
      "command": "node",
      "args": [
        "${workspaceFolder}/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "${workspaceFolder}/zephix-backend",
        "${workspaceFolder}/zephix-frontend",
        "${workspaceFolder}/docs",
        "${workspaceFolder}/scripts",
        "${workspaceFolder}/.cursor"
      ]
    }
  }
}
